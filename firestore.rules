/* ============================================================
   REGLAS DE SEGURIDAD — ORNATA JEWELRY (Firestore)
   ------------------------------------------------------------
   Cópialas y pégalas en:
   https://console.firebase.google.com/project/ornata-jewelry/firestore/rules
   y pulsa PUBLICAR.

   Qué hacen:
   - Cualquiera puede VER el catálogo (necesario para la tienda).
   - Solo el correo del administrador puede MODIFICAR algo.
     Aunque alguien se cree una cuenta, no podrá escribir nada.
   ============================================================ */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email == "romeropizarroangelo@gmail.com";
    }
  }
}
